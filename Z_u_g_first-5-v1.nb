Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"e", " ", "=", " ", 
     RowBox[{"collision", " ", "energy", " ", "in", " ", "eV"}]}], ",", " ", 
    "r0", ",", " ", 
    RowBox[{"rend", " ", "-", " ", 
     RowBox[{"R", " ", "range"}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"computeCrossSect", "[", 
      RowBox[{
      "eV_", ",", "r0_", ",", "rend_", ",", " ", "mMin_", ",", "mMax_"}], 
      "]"}], ":=", " ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"allBs", ",", "eH", ",", "kk", ",", "crossSection"}], "}"}], ",",
        "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"eH", " ", "=", " ", 
         RowBox[{"eV", "/", "27.21"}]}], ";", "  ", 
        RowBox[{"(*", " ", 
         RowBox[{"energy", " ", "Hartree"}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"kk", "=", 
         SqrtBox[
          RowBox[{"2", " ", "\[Mu]", " ", "eH"}]]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{"m", " ", "-", " ", 
          RowBox[{"partial", " ", "waves"}]}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"allBs", " ", "=", " ", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"m", ",", 
             RowBox[{"computePhaseShifts", "[", 
              RowBox[{"m", ",", "eH", ",", "r0", ",", "rend"}], "]"}]}], 
            "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"m", ",", "mMin", ",", " ", "mMax"}], "}"}]}], "]"}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"crossSection", "=", 
         RowBox[{
          FractionBox["1", "kk"], 
          RowBox[{
           RowBox[{"Total", "[", 
            RowBox[{"allBs", ",", 
             RowBox[{"{", "1", "}"}]}], "]"}], "[", 
           RowBox[{"[", "2", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"eV", ",", "crossSection"}], "}"}]}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Up", " ", "to", " ", "this", " ", "partial", " ", "wave"}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"mMax", " ", "=", " ", "5"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"crossSection", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"computeCrossSect", "[", 
        RowBox[{
        "e", ",", " ", "r0", ",", " ", "rend", ",", "0", ",", "mMax"}], "]"}],
        ",", 
       RowBox[{"{", 
        RowBox[{"e", ",", " ", "0.00001", ",", ".001", ",", " ", "0.00005"}], 
        "}"}]}], "]"}]}], ";"}]}]}]], "Input",
