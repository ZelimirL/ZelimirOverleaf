Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"ii", ":=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"e", " ", "=", " ", 
      RowBox[{"collision", " ", "energy", " ", "in", " ", "eV"}]}], ",", " ", 
     "r0", ",", " ", 
     RowBox[{"rend", " ", "-", " ", 
      RowBox[{"R", " ", "range"}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"computeCrossSect", "[", 
      RowBox[{"temp_", ",", "r0_", ",", "rend_"}], "]"}], ":=", " ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "eV", ",", "allBs", ",", "eH", ",", "kH", ",", "crossSection"}], 
        "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"eV", " ", "=", " ", 
         RowBox[{"temp", "*", 
          RowBox[{"(", "8.6173*^-5", ")"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"eH", " ", "=", " ", 
         RowBox[{"eV", "/", "27.21"}]}], ";", "  ", 
        RowBox[{"(*", " ", 
         RowBox[{"energy", " ", "Hartree"}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"kH", "=", 
         SqrtBox[
          RowBox[{"2", " ", "\[Mu]", " ", "eH"}]]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{"m", " ", "-", " ", 
          RowBox[{"partial", " ", "waves"}]}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"allBs", " ", "=", " ", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"m", ",", 
             RowBox[{"computePhaseShifts", "[", 
              RowBox[{"m", ",", "eH", ",", "r0", ",", "rend", ",", "ii"}], 
              "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"m", ",", "0", ",", "10"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"++", "ii"}], ";", "\[IndentingNewLine]", 
        RowBox[{"crossSection", "=", 
         RowBox[{
          FractionBox["1", "kH"], 
          RowBox[{
           RowBox[{"Total", "[", 
            RowBox[{"allBs", ",", 
             RowBox[{"{", "1", "}"}]}], "]"}], "[", 
           RowBox[{"[", "2", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"temp", ",", "crossSection"}], "}"}]}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"From", " ", "0.001", "K"}], " ", "->", " ", 
     RowBox[{"1", "K"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"crossSection", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"computeCrossSect", "[", 
        RowBox[{"t", ",", " ", "r0", ",", " ", "rend"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", " ", "0.001", ",", "1", ",", "0.005"}], "}"}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"crossSectionGraphSC", "=", 
    RowBox[{"Interpolation", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"crossSection", "\[LeftDoubleBracket]", 
         RowBox[{"All", ",", "1"}], "\[RightDoubleBracket]"}], ",", 
        RowBox[{
         RowBox[{"crossSection", "\[LeftDoubleBracket]", 
          RowBox[{"All", ",", "2"}], "\[RightDoubleBracket]"}], "\[LeftDoubleBracket]", 
         RowBox[{"All", ",", "1"}], "\[RightDoubleBracket]"}]}], "}"}], "//", 
      "Transpose"}], "]"}]}], "\n", 
   RowBox[{
    RowBox[{"crossSectionGraphCT", "=", 
     RowBox[{"Interpolation", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"crossSection", "\[LeftDoubleBracket]", 
          RowBox[{"All", ",", "1"}], "\[RightDoubleBracket]"}], ",", 
         RowBox[{
          RowBox[{"crossSection", "\[LeftDoubleBracket]", 
           RowBox[{"All", ",", "2"}], "\[RightDoubleBracket]"}], "\[LeftDoubleBracket]", 
          RowBox[{"All", ",", "2"}], "\[RightDoubleBracket]"}]}], "}"}], "//",
        "Transpose"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"crossSectionGraphSC", "[", "e", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"e", ",", "0.01", ",", "1"}], "}"}], ",", 
     RowBox[{"AxesOrigin", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ",", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"\"\<t (K)\>\"", ",", "\"\<\[Sigma] (a0)\>\""}], "}"}]}], ",", 
     
     RowBox[{
     "PlotLabel", 
      "\[Rule]", "\"\<Scattering Cross Section (\!\(\*SubscriptBox[\(a\), \(0\
\)]\)) vs Temperature (K)\>\""}]}], "]"}], "\n", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"crossSectionGraphCT", "[", "e", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"e", ",", "0.01", ",", "1"}], "}"}], ",", 
     RowBox[{"AxesOrigin", "\[Rule]", 
