       RowBox[{"0", ",", "0"}], "}"}]}], ",", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"\"\<t (K)\>\"", 
        ",", "\"\<\[Sigma] (\!\(\*SubscriptBox[\(a\), \(0\)]\))\>\""}], 
       "}"}]}], ",", 
     RowBox[{
     "PlotLabel", 
      "\[Rule]", "\"\<Resonant Charge Transfer Cross Section (a0) vs \
Temperature (K)\>\""}]}], "]"}], "\[IndentingNewLine]"}]}]], "Input",
